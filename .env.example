# ---- LLM (provider-agnostic via LiteLLM) ---------------------------------
# Pick a model string per slot; the provider is implied by the prefix.
LLM_STORY_MODEL=anthropic/claude-haiku-4-5-20251001
LLM_CHAT_MODEL=anthropic/claude-sonnet-4-6
LLM_CORRECTION_MODEL=anthropic/claude-haiku-4-5-20251001
# Provider-specific chat request-body extras, as JSON (single-quote in a .env).
# DeepSeek V4 Flash non-thinking pin: '{"thinking": {"type": "disabled"}}'
# LLM_CHAT_EXTRA_BODY=

# Provide whichever key matches your LLM_*_MODEL strings.
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# ---- TTS -----------------------------------------------------------------
# `elevenlabs` (default) or `inworld`. Both implement the same TTSProvider
# protocol; per-language voice IDs win over the default when set.
TTS_PROVIDER=elevenlabs

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_VOICE_ID_DE=
ELEVENLABS_VOICE_ID_ES=
ELEVENLABS_VOICE_ID_FR=
ELEVENLABS_VOICE_ID_JA=
ELEVENLABS_VOICE_ID_PT=
ELEVENLABS_VOICE_ID_EN=
# Realtime model (Speak replies — latency-sensitive) and narration model
# (pre-cached story audio — expressiveness wins, latency irrelevant).
ELEVENLABS_MODEL=eleven_flash_v2_5
ELEVENLABS_NARRATION_MODEL=eleven_multilingual_v2

# Inworld voices are language-locked; the per-language mapping matters more
# here than for ElevenLabs. The API key from Inworld Portal is already
# base64-encoded — paste it as-is.
INWORLD_API_KEY=
INWORLD_VOICE_ID=
INWORLD_VOICE_ID_DE=
INWORLD_VOICE_ID_ES=
INWORLD_VOICE_ID_FR=
INWORLD_VOICE_ID_JA=
INWORLD_VOICE_ID_PT=
INWORLD_VOICE_ID_EN=
INWORLD_MODEL=inworld-tts-1.5-mini

# ---- Pronunciation (Azure Cognitive Services Speech) ---------------------
# Without these, /api/v1/pronunciation/score and /quiz/resolve-mc return 503
# and the frontend hides the mic affordance.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

# ---- Auth ----------------------------------------------------------------
# Change AUTH_JWT_SECRET for any non-local deployment.
AUTH_JWT_SECRET=dev-secret-do-not-use-in-prod-change-me-32b

# First-run bootstrap: the email below adopts the legacy user row on its
# first signup and becomes a superuser. Leave empty after the owner exists.
INITIAL_OWNER_EMAIL=

# Optional Google OAuth. Callback URL must match BACKEND_BASE_URL +
# /api/v1/auth/google/callback and be registered in Google Cloud Console.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Outbound email for verify / reset links (Resend).
RESEND_API_KEY=
EMAIL_FROM=Klara <noreply@klara.app>

# ---- URLs ----------------------------------------------------------------
# Used inside emails and the OAuth redirect. Set to the public origins in prod.
FRONTEND_BASE_URL=http://localhost:5273
BACKEND_BASE_URL=http://localhost:8000

# CORS allowlist (comma-separated).
CORS_ORIGINS=http://localhost:5273,http://127.0.0.1:5273

# ---- Postgres ------------------------------------------------------------
POSTGRES_USER=german
POSTGRES_PASSWORD=german_dev_pw
POSTGRES_DB=german_app
