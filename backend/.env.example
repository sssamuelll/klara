APP_ENV=development
APP_LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://german:german_dev_pw@localhost:5432/german_app

LLM_PROVIDER=anthropic
LLM_STORY_MODEL=anthropic/claude-haiku-4-5-20251001
LLM_CHAT_MODEL=anthropic/claude-sonnet-4-6
LLM_CORRECTION_MODEL=anthropic/claude-haiku-4-5-20251001

ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

DEFAULT_USER_DISPLAY_NAME=Samuel
DEFAULT_USER_LEVEL=A0
DEFAULT_USER_NATIVE_LANGUAGE=es
DEFAULT_USER_TARGET_LANGUAGE=de
DEFAULT_USER_LEARNING_CONTEXT=

# --- TTS ----------------------------------------------------------------
# Provider switch. Currently supported: "elevenlabs", "inworld".
TTS_PROVIDER=elevenlabs

# Per-language voice overrides. Each TTS voice has a *native* language and
# sounds non-native in others (e.g. Bella is great in German but mauls
# Spanish). The frontend passes ?lang=<iso-639-1> on TTS calls; the provider
# picks ELEVENLABS_VOICE_ID_<LANG> if set, else falls back to the generic
# ELEVENLABS_VOICE_ID. Same pattern for Inworld below.
#
# Pick voices at:
#   https://elevenlabs.io/app/voice-library  (filter by language)
ELEVENLABS_VOICE_ID_DE=
ELEVENLABS_VOICE_ID_ES=
ELEVENLABS_VOICE_ID_FR=
ELEVENLABS_VOICE_ID_JA=
ELEVENLABS_VOICE_ID_PT=
ELEVENLABS_VOICE_ID_EN=

# Inworld TTS (only consulted when TTS_PROVIDER=inworld).
# The API key from https://portal.inworld.ai is already base64-encoded — paste
# it as-is, do NOT re-encode for Basic auth. To discover voices per language:
#   curl -H "Authorization: Basic $INWORLD_API_KEY" \
#     "https://api.inworld.ai/tts/v1/voices?filter=language=de" | jq '.voices[].voiceId'
INWORLD_API_KEY=
INWORLD_VOICE_ID=
INWORLD_VOICE_ID_DE=
INWORLD_VOICE_ID_ES=
INWORLD_VOICE_ID_FR=
INWORLD_VOICE_ID_JA=
INWORLD_VOICE_ID_PT=
INWORLD_VOICE_ID_EN=
INWORLD_MODEL=inworld-tts-1.5-mini

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Auth ---------------------------------------------------------------
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(48))'
AUTH_JWT_SECRET=change-me-in-prod-min-32-bytes
AUTH_COOKIE_NAME=klara_session
AUTH_COOKIE_MAX_AGE=2592000

# When this email registers, it adopts the legacy single-user row (Samuel's
# stories/vocab/cards) instead of creating a new user. Bootstrap-only — once
# the owner exists, every new account must arrive via an admin-issued invite
# token (see /admin/invitations).
INITIAL_OWNER_EMAIL=

# Google OAuth — leave blank to disable the /api/v1/auth/google/* routes.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Email (Resend). Empty key → stub mode (links logged, no email sent).
RESEND_API_KEY=
EMAIL_FROM=Klara <noreply@klara.app>

# Where the SPA lives (used to build verify/reset links in emails).
FRONTEND_BASE_URL=http://localhost:5273
# Where the API lives (used as the OAuth redirect_uri so Google posts the
# callback to /api/v1/auth/google/callback). Must match the URL registered
# in the Google Cloud Console OAuth client.
BACKEND_BASE_URL=http://localhost:8000

# --- Pronunciation (Azure AI Speech) -----------------------------------
# Without a key, POST /api/v1/pronunciation/score returns 503 and the
# frontend silently falls back to the simulated scoring. Free tier (F0)
# gives 5 h of audio/month.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus
