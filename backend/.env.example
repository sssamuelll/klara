APP_ENV=development
APP_LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://german:german_dev_pw@localhost:5432/german_app

LLM_PROVIDER=anthropic
LLM_STORY_MODEL=anthropic/claude-haiku-4-5-20251001
LLM_CHAT_MODEL=anthropic/claude-sonnet-4-6
LLM_CORRECTION_MODEL=anthropic/claude-haiku-4-5-20251001

ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

DEFAULT_USER_DISPLAY_NAME=Samuel
DEFAULT_USER_LEVEL=A0
DEFAULT_USER_NATIVE_LANGUAGE=es
DEFAULT_USER_TARGET_LANGUAGE=de
DEFAULT_USER_LEARNING_CONTEXT=

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Auth ---------------------------------------------------------------
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(48))'
AUTH_JWT_SECRET=change-me-in-prod-min-32-bytes
AUTH_COOKIE_NAME=klara_session
AUTH_COOKIE_MAX_AGE=2592000

# Comma-separated allowlist. Anyone outside this list gets 403 on signup.
# Leave empty to disable the gate (open registration).
ALLOWED_SIGNUP_EMAILS=

# When this email registers, it adopts the legacy single-user row (Samuel's
# stories/vocab/cards) instead of creating a new user.
INITIAL_OWNER_EMAIL=

# Google OAuth — leave blank to disable the /api/v1/auth/google/* routes.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Email (Resend). Empty key → stub mode (links logged, no email sent).
RESEND_API_KEY=
EMAIL_FROM=Klara <noreply@klara.app>

# Where the SPA lives (used to build verify/reset links in emails).
FRONTEND_BASE_URL=http://localhost:5273
# Where the API lives (used as the OAuth redirect_uri so Google posts the
# callback to /api/v1/auth/google/callback). Must match the URL registered
# in the Google Cloud Console OAuth client.
BACKEND_BASE_URL=http://localhost:8000
